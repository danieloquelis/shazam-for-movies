# Mobile build-time environment.
#
# Copy to `.env` (which is gitignored via `.env*.local` rules) and fill in.
# Variables starting with EXPO_PUBLIC_ are inlined into the JS bundle and are
# readable from anywhere in the app via `process.env` or `app.config.ts`.

# Backend base URL.
#  - iOS Simulator can reach the host via http://localhost:8000
#  - iOS device: use the host machine's LAN IP (e.g. http://192.168.1.42:8000)
#  - Android emulator: use http://10.0.2.2:8000
#  - Android device: LAN IP of the host machine
EXPO_PUBLIC_API_URL=http://localhost:8000

# Must match the API_KEY env var on the backend.
EXPO_PUBLIC_API_KEY=dev-key-change-me
